# ------------------------------------------------------------------
# Supabase / PostgreSQL Connection Settings
# Supabase Dashboard -> Project Settings -> Database -> Connection String
# ------------------------------------------------------------------

# Session Pooler (port 5432) onerilir. Transaction Pooler (port 6543)
# kullanacaksaniz DB_USE_TRANSACTION_POOLER=true yapin (asyncpg prepared
# statement cache otomatik kapatilir).
DATABASE_URL=postgresql+asyncpg://postgres.<project-ref>:<db-password>@aws-0-eu-central-1.pooler.supabase.com:5432/postgres
DB_USE_TRANSACTION_POOLER=false

# Connection pool tuning
DB_POOL_SIZE=10
DB_MAX_OVERFLOW=5
DB_POOL_TIMEOUT_SECONDS=30

# Supabase API (Auth ve Storage entegrasyonlari icin, ileride kullanilacak)
SUPABASE_URL=https://<project-ref>.supabase.co
SUPABASE_ANON_KEY=<anon-key>
SUPABASE_SERVICE_ROLE_KEY=<service-role-key>
# JWT Secret: Dashboard -> Project Settings -> API -> "JWT Settings" -> JWT Secret.
# Bearer token'larin HS256 imza dogrulamasi icin zorunludur (bos ise auth uclari 503 doner).
SUPABASE_JWT_SECRET=<jwt-secret>

# AI - Google AI Studio (https://aistudio.google.com/apikey)
# Bos birakilirsa /api/v1/analysis/* uclari 503 doner.
GEMINI_API_KEY=
GEMINI_MODEL=gemini-2.5-flash-lite

# RevenueCat webhook (Dashboard -> Integrations -> Webhooks -> Authorization header)
# Bos birakilirsa POST /api/v1/webhooks/revenuecat 503 doner.
REVENUECAT_WEBHOOK_SECRET=

# App
APP_ENV=development
