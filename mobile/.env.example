# EXPO_PUBLIC_* degerleri build'e gomulur; yalnizca istemcide guvenli degerler.
# Service role key, JWT secret veya Gemini key ASLA buraya yazilmaz.

# Backend koku. iOS simulatorde localhost calisir; gercek cihazda Mac'in
# LAN IP'sini (orn. http://192.168.1.20:8000) veya deploy edilmis dev
# ortamini kullanin. Android emulatorde http://10.0.2.2:8000.
EXPO_PUBLIC_API_BASE_URL=http://localhost:8000

# Supabase (backend ile ayni proje). Dashboard -> Project Settings -> API
EXPO_PUBLIC_SUPABASE_URL=https://<project-ref>.supabase.co
EXPO_PUBLIC_SUPABASE_ANON_KEY=<anon-key>
